{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deep-research-ppt-v1/ppt_plan.schema.json",
  "title": "PPT Plan",
  "type": "object",
  "additionalProperties": true,
  "required": ["title", "ppt_style", "steps"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "ppt_style": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["title", "description", "need_search", "step_type"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "need_search": { "type": "boolean" },
          "step_type": { "type": "string", "const": "research" }
        }
      }
    }
  }
}
